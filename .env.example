# PayPal — frontend
VITE_PAYPAL_CLIENT_ID=your_sandbox_client_id_here

# PayPal — Supabase edge functions (set these in your Supabase project secrets)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
# Set to "live" for production; omit or set to "sandbox" for testing
PAYPAL_ENV=sandbox
